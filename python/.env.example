# ── Vapi (voice agent + telephony) ─────────────────────────────
# Sign up at https://vapi.ai, then grab your private key + a phone number id.
VAPI_API_KEY=your_vapi_private_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id

# ── LLM brain (Gemini) + Voice (ElevenLabs) ───────────────────
# IMPORTANT: these providers' API keys do NOT go here. Add your Google/Gemini
# key and your ElevenLabs key in the Vapi dashboard (Providers) — Vapi makes
# the calls. Here you only choose which provider/model/voice to use.
LLM_PROVIDER=google
AGENT_MODEL=gemini-2.0-flash
VOICE_PROVIDER=11labs
# Pick a voice id from your ElevenLabs library (default below = "Rachel").
ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Ears (speech-to-text). Deepgram is Vapi's default + the telephony standard.
STT_PROVIDER=deepgram
STT_MODEL=nova-2

# ── Push: tap-to-pick decisions for edge cases (ntfy.sh) ───────
# Install the ntfy app, pick a private, hard-to-guess topic name, subscribe to
# it. Edge-case approvals arrive as a push with tappable buttons.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=appt-yourname-9f3k2x-change-me

# Seconds the agent holds the operator while waiting for your tap.
# Must be < the assistant's Vapi tool timeout (set to 30 in agent.py).
DECISION_TIMEOUT_SECONDS=25
# If you don't tap in time on an edge case: "closest" (book soonest offered) or
# "decline" (book nothing, safe).
EDGE_FALLBACK=closest

# ── Twilio (optional: SMS confirmations to YOU) ────────────────
# Push (above) is the primary channel now. Twilio is only used for the optional
# SMS confirmations in notify.py; leave blank to disable.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_PHONE_NUMBER=

# ── Your server's public URL (Vapi + Twilio webhooks hit this) ─
# In dev, run `ngrok http 8000` and paste the https URL here.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.app

# Shared secret Vapi sends back so we can verify webhook authenticity.
VAPI_WEBHOOK_SECRET=generate_a_random_string
