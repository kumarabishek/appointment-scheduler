# Copy to .env.local and fill in. Next.js loads .env.local automatically.

# ── Auth (Clerk) ───────────────────────────────────────────────
# Install Clerk from the Vercel Marketplace to auto-provision these two keys:
#   CLERK_SECRET_KEY=sk_...
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# For local dev, copy them from the Vercel project into .env.local.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Database (Postgres — Neon in prod, same URL locally) ───────
# Call records live here (replaces the old JSON file, so it works on serverless).
# Create a free Neon DB (neon.tech) or use Vercel's Postgres/Neon integration.
# Then: npx prisma migrate dev --name init   (creates the tables)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Vapi (voice agent + telephony) ─────────────────────────────
VAPI_API_KEY=your_vapi_private_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_WEBHOOK_SECRET=generate_a_random_string

# ── LLM brain (Gemini) + Voice (ElevenLabs) + Ears (Deepgram) ──
# IMPORTANT: these providers' API keys go in the Vapi dashboard (Providers),
# NOT here. Below you only choose which provider/model/voice to use.
LLM_PROVIDER=google
AGENT_MODEL=gemini-2.5-flash
VOICE_PROVIDER=11labs
ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM
STT_PROVIDER=deepgram
STT_MODEL=nova-2

# ── Push: tap-to-pick decisions (ntfy.sh) — OPTIONAL ───────────
# Leave NTFY_TOPIC blank to disable live approval: edge cases (no slot fits your
# windows) apply EDGE_FALLBACK automatically and show on the dashboard instead.
# Set a private topic to enable real-time tap-to-approve while the agent holds.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
DECISION_TIMEOUT_SECONDS=25
EDGE_FALLBACK=closest

# ── Public URL for inbound webhooks (ngrok in dev) ─────────────
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.app

# ── PHI encryption (whole record at rest) ──────────────────────
# Encrypts the ENTIRE call record JSON in Postgres (name, DOB, insurance,
# callback, reason, notes, transcript). Generate a strong secret:
#   openssl rand -base64 32
# Required in production — the store throws rather than persist plaintext PHI.
# NOTE: the call itself runs with Vapi HIPAA mode on (no recordings/transcripts
# stored at Vapi), and approval pushes carry no patient name/reason.
PHI_ENCRYPTION_KEY=

# ── Test IVR harness (off by default) ──────────────────────────
# The /api/test-ivr routes are a local dev harness and are PUBLIC (Twilio is a
# machine). Keep them OFF in production so the operator number can't be probed.
# Set to true only while actively testing IVR navigation.
TEST_IVR_ENABLED=false

# ── Testing: fake IVR + recording toggle ───────────────────────
# HIPAA_MODE=false turns Vapi recordings/transcripts back ON so you can review
# test calls in the dashboard. Use ONLY with fake data; leave true otherwise.
HIPAA_MODE=true
# The "operator" number the fake test IVR dials after the agent presses 1.
# Set to your own cell to role-play the scheduler. See scripts/test-ivr/README.md
TEST_OPERATOR_PHONE=

# ── Google Calendar push (optional) ────────────────────────────
# If set, booked appointments become real Google Calendar events; if blank,
# they fall back to a local data/appointments.ics file.
# 1) In Google Cloud Console: enable Calendar API, make an OAuth Web client,
#    add http://localhost:5858/oauth2callback as a redirect URI.
# 2) GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=... npm run google-auth
#    -> follow the URL, then paste the printed refresh token below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
# Timezone is normally auto-detected from the booker's browser per request.
# This is only a server-side FALLBACK for a request that arrives without one.
CALENDAR_TIMEZONE=America/Los_Angeles
APPOINTMENT_DURATION_MINUTES=30
